{
  "expo": {
    "name": "Dellite Partner",
    "slug": "dellite-partner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Dellite Partner to use your location for service and job updates.",
        "NSFaceIDUsageDescription": "Dellite uses Face ID to protect your payout information."
      }
    },
    "android": {
      "package": "com.dellite.partner",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "065cbb17-5fe4-418c-bd9f-1a4a2a13ae30"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dellite Partner to use your camera for Aadhaar QR verification."
        }
      ]
    ]
  }
}
